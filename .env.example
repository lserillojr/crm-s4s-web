# .env.example — copiar pra .env.local (NUNCA commitar .env.local)
#
# SP2 fase 1: só DATABASE_URL é obrigatória. AUTH/N8N/RESEND entram em fases
# seguintes conforme features destravarem.

# === Database (obrigatória) ===
# ATENÇÃO (decisão 6d): NÃO é mais SELECT-only. O login faz upsert app-side em
# `users` (sync do Keycloak no callback signIn), então o user precisa de
# INSERT+UPDATE em `users` além do SELECT de leitura. Um user read-only quebra
# TODO login (signIn é fail-closed). Grants mínimos:
#   GRANT SELECT ON ALL TABLES IN SCHEMA public TO crm_s4s_web;
#   GRANT INSERT, UPDATE ON users TO crm_s4s_web;
DATABASE_URL=postgres://crm_s4s_web:CHANGE_ME@138.199.227.1:5433/crm_s4s?sslmode=disable

# === Auth (SP2 fase 2 — quando Keycloak SP1 estiver pronto) ===
# Gerar AUTH_SECRET: `openssl rand -base64 32`
AUTH_SECRET=
AUTH_KEYCLOAK_ID=web-simples
AUTH_KEYCLOAK_SECRET=
AUTH_KEYCLOAK_ISSUER=https://dev-auth.staff4solutions.com.br/realms/s4s

# === n8n API (Wizard SP4) ===
N8N_API_BASE_URL=https://dev-editor.staff4solutions.com.br
N8N_PROVISION_API_KEY=
# Dashboard summary (Story 7.5) — token de serviço dos WFs n8n
N8N_AI_SERVICE_TOKEN=        # = global_config.ai_service_token no Postgres crm_s4s

# === Resend (transactional emails) ===
RESEND_API_KEY=

# Push (Onda 1/B) — app nativo MEI
EXPO_ACCESS_TOKEN=
PUSH_WEBHOOK_SECRET=

# === SSO launchers (Plano E Fase 2) — URLs publicas das ferramentas do MEI ===
# Chatwoot: rota same-origin /sso/openid_connect/start (imagem crm-s4s-chatwoot).
# Odoo: login page com botao nativo "Keycloak S4S".
NEXT_PUBLIC_CHATWOOT_URL=https://dev-chat.staff4solutions.com.br
NEXT_PUBLIC_ODOO_URL=https://dev-backoffice.staff4solutions.com.br
