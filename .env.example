# .env.example — copiar pra .env.local (NUNCA commitar .env.local)
#
# SP2 fase 1: só DATABASE_URL é obrigatória. AUTH/N8N/RESEND entram em fases
# seguintes conforme features destravarem.

# === Database (obrigatória) ===
# Postgres dedicated user com SELECT-only nas tables relevantes.
# Lauri precisa criar `crm_s4s_web_ro` no Postgres DEV (ver Task 6 Step 3 do plan).
DATABASE_URL=postgres://crm_s4s_web_ro:CHANGE_ME@138.199.227.1:5433/crm_s4s?sslmode=disable

# === Auth (SP2 fase 2 — quando Keycloak SP1 estiver pronto) ===
# Gerar AUTH_SECRET: `openssl rand -base64 32`
AUTH_SECRET=
AUTH_KEYCLOAK_ID=web-simples
AUTH_KEYCLOAK_SECRET=
AUTH_KEYCLOAK_ISSUER=https://dev-auth.staff4solutions.com.br/realms/s4s-prod

# === n8n API (Wizard SP4) ===
N8N_API_BASE_URL=https://dev-editor.staff4solutions.com.br
N8N_PROVISION_API_KEY=

# === Resend (transactional emails) ===
RESEND_API_KEY=
